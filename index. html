Sketchbook flamingo.com<!DOCTYPE html>
<html lang="en" data-theme="flamingo">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JOSHUA • CHAOS CAFÉ</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Comic+Neue:wght@400;700&family=Space+Grotesk:wght@400;600&display=swap');

        :root {
            --pink: #ff69b4;
            --cyan: #00f0ff;
            --lime: #39ff14;
            --purple: #9b4dff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0a0a1f;
            color: #fff;
            font-family: 'Comic Neue', cursive;
            overflow-x: hidden;
            cursor: url('https://i.imgur.com/0zY7Z8K.png'), auto;
        }

        .theme-tropical { --accent: #ff69b4; }
        .theme-midnight { --accent: #00f0ff; }
        .theme-sketch { --accent: #39ff14; }

        /* Navbar */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(10, 10, 31, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            padding: 15px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid var(--pink);
        }

        .logo {
            font-family: 'Press Start 2P', system-ui;
            font-size: 1.5rem;
            color: var(--pink);
            text-shadow: 0 0 10px var(--pink);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-links a {
            color: white;
            margin: 0 20px;
            text-decoration: none;
            font-weight: bold;
            transition: all 0.3s;
        }

        .nav-links a:hover {
            color: var(--pink);
            text-shadow: 0 0 15px var(--pink);
        }

        /* Hero */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            background: linear-gradient(45deg, #1a0033, #003322);
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('https://picsum.photos/id/1015/1920/1080') center/cover;
            opacity: 0.15;
        }

        .hero-content {
            z-index: 2;
            max-width: 900px;
        }

        .hero h1 {
            font-size: 4.5rem;
            margin-bottom: 20px;
            background: linear-gradient(90deg, #ff69b4, #00f0ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 30px rgba(255, 105, 180, 0.5);
        }

        .hero p {
            font-size: 1.8rem;
            margin-bottom: 40px;
            color: #ddd;
        }

        .btn-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 50px;
        }

        .btn {
            padding: 20px 30px;
            font-size: 1.3rem;
            border: 4px solid var(--pink);
            background: rgba(0, 0, 0, 0.6);
            color: white;
            cursor: pointer;
            transition: all 0.4s;
            font-family: 'Press Start 2P';
            text-transform: uppercase;
        }

        .btn:hover {
            background: var(--pink);
            transform: scale(1.1) rotate(2deg);
            box-shadow: 0 0 40px var(--pink);
        }

        /* Flamingos */
        .flamingo {
            position: absolute;
            font-size: 4rem;
            animation: walkAcross 25s linear infinite;
            opacity: 0.7;
            z-index: 1;
        }

        @keyframes walkAcross {
            0% { transform: translateX(-200px) rotate(-15deg); }
            100% { transform: translateX(2000px) rotate(15deg); }
        }

        /* Sections */
        section {
            padding: 100px 8%;
        }

        h2 {
            font-family: 'Press Start 2P';
            font-size: 3rem;
            margin-bottom: 60px;
            text-align: center;
            color: var(--pink);
        }

        /* Art Gallery - Pinterest Masonry */
        .masonry {
            column-count: 4;
            column-gap: 20px;
        }

        @media (max-width: 1200px) { .masonry { column-count: 3; } }
        @media (max-width: 800px) { .masonry { column-count: 2; } }

        .masonry-item {
            break-inside: avoid;
            margin-bottom: 20px;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            transition: all 0.4s;
        }

        .masonry-item:hover {
            transform: scale(1.05) rotate(1deg);
            box-shadow: 0 20px 40px rgba(255, 105, 180, 0.4);
        }

        .masonry-item img {
            width: 100%;
            display: block;
        }

        .caption {
            padding: 15px;
            background: rgba(10, 10, 31, 0.9);
            font-size: 0.9rem;
        }

        /* Video Section */
        .video-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
            gap: 30px;
        }

        .video-card {
            background: #1a1a2e;
            border-radius: 15px;
            overflow: hidden;
            border: 3px solid #00f0ff;
        }

        /* Music Toggle */
        #music-toggle {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: rgba(255, 105, 180, 0.9);
            color: white;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            z-index: 9999;
            box-shadow: 0 0 30px #ff69b4;
            cursor: pointer;
        }

        /* Easter Eggs */
        .secret {
            display: none;
        }

        .sticky-note {
            position: fixed;
            background: #ff0;
            color: #000;
            padding: 15px;
            transform: rotate(-8deg);
            box-shadow: 5px 5px 0 #000;
            font-weight: bold;
            z-index: 100;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav>
        <div class="logo">
            🦩 JOSHUA'S CHAOS CAFÉ
        </div>
        <div class="nav-links">
            <a href="#art">🎨 Art</a>
            <a href="#vlogs">🎥 Vlogs</a>
            <a href="#cafe">🥤 Café</a>
            <a href="#secrets">🕵️ Secrets</a>
        </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
        <div class="hero-content">
            <h1>ART.<br>VLOGS.<br>WEIRD SECRETS.<br>TINY CHAOS.</h1>
            <p>Pinterest at 2AM meets tropical flamingo café</p>
            
            <div class="btn-grid">
                <div onclick="navigateTo('art')" class="btn">🎨 VIEW ART</div>
                <div onclick="navigateTo('vlogs')" class="btn">🎥 WATCH VLOGS</div>
                <div onclick="navigateTo('cafe')" class="btn">🥤 ENTER CAFÉ</div>
                <div onclick="findSecrets()" class="btn">🕵️ FIND EASTER EGGS</div>
            </div>
        </div>

        <!-- Random Flamingos -->
        <div class="flamingo" style="top: 20%; animation-delay: 0s;">🦩</div>
        <div class="flamingo" style="top: 45%; animation-delay: 8s;">🦩</div>
        <div class="flamingo" style="top: 65%; animation-delay: 15s;">🦩</div>
    </section>

    <!-- Art Section -->
    <section id="art">
        <h2>🖼️ ART DUMP</h2>
        <div class="masonry" id="art-gallery">
            <!-- Will be populated by JS -->
        </div>
    </section>

    <!-- Vlogs -->
    <section id="vlogs" style="background: #001122;">
        <h2>🎥 VLOGS &amp; SPEEDPAINTS</h2>
        <div class="video-grid">
            <div class="video-card">
                <div style="height: 220px; background: #000; display: flex; align-items: center; justify-content: center; font-size: 4rem;">📹</div>
                <div style="padding: 20px;">
                    <h3>Night Market Chaos in Abuja</h3>
                    <p>Retro camcorder filter • 12:42</p>
                    <button onclick="playFakeVideo(this)" style="margin-top: 10px; padding: 10px 20px; background: #00f0ff; border: none; color: black; font-weight: bold;">PLAY WITH FILTER</button>
                </div>
            </div>
            <div class="video-card">
                <div style="height: 220px; background: #000; display: flex; align-items: center; justify-content: center; font-size: 4rem;">🎨</div>
                <div style="padding: 20px;">
                    <h3>Speedpaint: Neon Flamingo OC</h3>
                    <p>3.5 hours condensed • 2x speed</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Café -->
    <section id="cafe">
        <h2>🥤 THE FLAMINGO CAFÉ</h2>
        <p style="text-align: center; font-size: 1.5rem; max-width: 700px; margin: 0 auto 60px;">
            Lo-fi beats • Digital sketchbooks • Random sticky notes • Good vibes only
        </p>
        
        <div style="display: flex; justify-content: center; gap: 40px; flex-wrap: wrap;">
            <div style="text-align: center; max-width: 300px;">
                <div style="font-size: 6rem; margin-bottom: 20px;">☕</div>
                <h3>Guestbook Wall</h3>
                <textarea id="guestbook" placeholder="Leave a chaotic message..." style="width: 100%; height: 120px; background: #112233; border: 3px solid #ff69b4; color: white; padding: 15px;"></textarea>
                <button onclick="signGuestbook()" style="margin-top: 10px;">SIGN THE WALL</button>
            </div>
            
            <div style="text-align: center;">
                <div style="font-size: 6rem;">🦩</div>
                <h3>Tiny Pet Flamingo</h3>
                <button onclick="flamingoScream()" style="padding: 15px 40px; font-size: 1.2rem;">MAKE HIM SCREAM</button>
            </div>
        </div>
    </section>

    <!-- Secrets -->
    <section id="secrets" style="background: #220033;">
        <h2>🕵️ THE SECRET ZONE</h2>
        <div style="text-align: center; font-size: 1.4rem;">
            <p>Click random doodles. Type the Konami code. Stars change the vibe.</p>
            <div style="margin: 40px 0; font-size: 5rem; cursor: pointer;" onclick="changeTheme()">✨</div>
            <p><em>Hint: There's more than meets the eye...</em></p>
        </div>
    </section>

    <!-- Music Toggle -->
    <div id="music-toggle" onclick="toggleMusic()">♪</div>

    <!-- Audio -->
    <audio id="bg-music" loop>
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
    </audio>

    <!-- Floating sticky note -->
    <div id="sticky" class="sticky-note" style="top: 30%; left: 10%; display: none;">
        "never finish the drawing" - me at 3am
    </div>

    <script>
        // Sample art pieces
        const artPieces = [
            {url: "https://picsum.photos/id/1015/600/800", caption: "Neon OC #47"},
            {url: "https://picsum.photos/id/201/600/400", caption: "Abuja Nights"},
            {url: "https://picsum.photos/id/133/500/700", caption: "Flamingo Dreams"},
            {url: "https://picsum.photos/id/251/600/900", caption: "Speedpaint WIP"},
            {url: "https://picsum.photos/id/180/700/500", caption: "Sketchbook Dump"},
            {url: "https://picsum.photos/id/870/500/800", caption: "Tropical Chaos"}
        ];

        function populateGallery() {
            const gallery = document.getElementById('art-gallery');
            artPieces.forEach(piece => {
                const div = document.createElement('div');
                div.className = 'masonry-item';
                div.innerHTML = `
                    <img src="${piece.url}" alt="${piece.caption}" onclick="clickDoodle(this)">
                    <div class="caption">${piece.caption}</div>
                `;
                gallery.appendChild(div);
            });
        }

        // Click doodle easter egg
        function clickDoodle(img) {
            if (Math.random() > 0.7) {
                alert("🔓 You found a hidden page! (imagine a cool secret page here)");
                document.getElementById('sticky').style.display = 'block';
                setTimeout(() => document.getElementById('sticky').style.display = 'none', 4000);
            } else {
                img.style.filter = "hue-rotate(90deg) saturate(2)";
                setTimeout(() => img.style.filter = "", 800);
            }
        }

        function navigateTo(section) {
            document.getElementById(section).scrollIntoView({ behavior: "smooth" });
        }

        function toggleMusic() {
            const audio = document.getElementById('bg-music');
            if (audio.paused) {
                audio.play();
                document.getElementById('music-toggle').innerHTML = '⏸️';
            } else {
                audio.pause();
                document.getElementById('music-toggle').innerHTML = '♪';
            }
        }

        function flamingoScream() {
            const screams = ["SCREEEE!", "HONK HONK CHAOS", "🦩 AAAAAA", "TROPICAL SCREAM ACTIVATED"];
            alert(screams[Math.floor(Math.random() * screams.length)]);
            
            // Sparkle effect
            for (let i = 0; i < 15; i++) {
                setTimeout(() => {
                    console.log("✨");
                }, i * 80);
            }
        }

        function signGuestbook() {
            const ta = document.getElementById('guestbook');
            if (ta.value.trim()) {
                alert("📝 Guestbook updated! Your message has been added to the chaos wall.");
                ta.value = "";
            }
        }

        function playFakeVideo(btn) {
            btn.innerHTML = "📼 RETRO FILTER ON";
            btn.style.background = "#ff00ff";
            setTimeout(() => {
                alert("📼 Playing vlog with heavy VHS glitch + tropical rain sounds...");
            }, 600);
        }

        function changeTheme() {
            const themes = ['flamingo', 'midnight', 'sketch'];
            const current = document.documentElement.getAttribute('data-theme');
            let next = themes[(themes.indexOf(current) + 1) % 3];
            document.documentElement.setAttribute('data-theme', next);
            
            const colors = {
                flamingo: '#ff69b4',
                midnight: '#00f0ff',
                sketch: '#39ff14'
            };
            document.documentElement.style.setProperty('--pink', colors[next]);
        }

        function findSecrets() {
            alert("🕵️ Good job detective. Try pressing ↑ ↑ ↓ ↓ ← → ← → B A on your keyboard...");
            konamiActive = true;
        }

        // Konami Code
        let konamiCode = [];
        const konamiPattern = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'KeyB', 'KeyA'];
        let konamiActive = false;

        document.addEventListener('keydown', (e) => {
            konamiCode.push(e.code);
            if (konamiCode.length > konamiPattern.length) konamiCode.shift();
            
            if (JSON.stringify(konamiCode) === JSON.stringify(konamiPattern)) {
                document.body.style.transition = "filter 1s";
                document.body.style.filter = "invert(1) hue-rotate(180deg)";
                alert("🌑 DARK MODEM UNLOCKED. Welcome to the void, artist.");
                setTimeout(() => document.body.style.filter = "", 3000);
                konamiCode = [];
            }
        });

        // Cursor sparkles
        document.addEventListener('mousemove', (e) => {
            if (Math.random() > 0.85) {
                const sparkle = document.createElement('div');
                sparkle.textContent = '✦';
                sparkle.style.position = 'fixed';
                sparkle.style.left = e.clientX + 'px';
                sparkle.style.top = e.clientY + 'px';
                sparkle.style.color = '#ff69b4';
                sparkle.style.fontSize = '20px';
                sparkle.style.pointerEvents = 'none';
                sparkle.style.zIndex = '99999';
                sparkle.style.animation = 'sparkleAnim 1s forwards';
                document.body.appendChild(sparkle);
                
                setTimeout(() => sparkle.remove(), 1000);
            }
        });

        // Add sparkle animation
        const style = document.createElement('style');
        style.innerHTML = `
            @keyframes sparkleAnim {
                0% { transform: scale(1); opacity: 1; }
                100% { transform: scale(0.2) translateY(-80px); opacity: 0; }
            }
        `;
        document.head.appendChild(style);

        // Initialize
        window.onload = function() {
            populateGallery();
            
            // Auto play music hint
            setTimeout(() => {
                console.log("%c💡 Tip: Click the music button for lo-fi tropical beats", "color: #ff69b4; font-size: 16px");
            }, 2000);
            
            // Random sticky note
            setInterval(() => {
                if (Math.random() > 0.8) {
                    document.getElementById('sticky').style.display = 'block';
                    setTimeout(() => {
                        document.getElementById('sticky').style.display = 'none';
                    }, 3500);
                }
            }, 15000);
        };
    </script>
</body>
</html>